# Etsy Multi-Tenant System - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 飞书配置 ====================
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 云途物流配置 ====================
YUNEXPRESS_APP_ID=your_yunexpress_app_id
YUNEXPRESS_APP_SECRET=your_yunexpress_app_secret
YUNEXPRESS_SOURCE_KEY=your_yunexpress_source_key

# 云途物流渠道（可选，使用默认值）
# YUNEXPRESS_CHANNEL_US=USTHPHR
# YUNEXPRESS_CHANNEL_OTHER=THPHR
# YUNEXPRESS_CHANNEL_US_ISLAND=THPDYPY

# ==================== 泰嘉物流配置 ====================
TAKESEND_CLIENT_ID=your_takesend_client_id
TAKESEND_AUTH_TOKEN=your_takesend_auth_token

# 泰嘉Web登录凭据（用于获取面单）
WEB_USERID=your_web_userid
WEB_PASSWORD=your_web_password

# ==================== 邮箱配置 ====================
# Yahoo 邮箱
YAHOO_EMAIL=your_email@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_app_password
YAHOO_IMAP_SERVER=imap.mail.yahoo.com
YAHOO_IMAP_PORT=993

# Gmail（可选）
# GMAIL_EMAIL=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_gmail_app_password

# ==================== OpenRouter AI 配置 ====================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# ==================== Label MVP API ====================
LABEL_MVP_URL=https://your-label-service.railway.app/api/label

# ==================== 阿里云 OSS 配置（面单存储）====================
OSS_ENDPOINT=https://oss-cn-hongkong.aliyuncs.com
OSS_BUCKET=your_bucket_name
OSS_KEY=your_oss_access_key
OSS_SECRET=your_oss_access_secret
OSS_CUSTOM_DOMAIN=labels.yourdomain.com

# ==================== Google Sheets 配置（可选）====================
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_SHEETS_NAME=工作表1
# Google Service Account JSON（单行，转义引号）
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ==================== Etsy API 配置（可选）====================
# ETSY_API_KEY=your_etsy_api_key
# ETSY_API_SECRET=your_etsy_api_secret

# ==================== 其他配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 邮件检查间隔（秒）
CHECK_INTERVAL_SECONDS=60

# IOSS 代码
IOSS_CODE=IM3720000224

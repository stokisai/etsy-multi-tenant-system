# Etsy Multi-Tenant System - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# Etsy API 配置
# ============================================
# 如果多个店铺共用同一个API Key，使用这个
ETSY_API_KEY=your_etsy_api_key
ETSY_API_SECRET=your_etsy_api_secret

# 如果不同店铺使用不同的API Key，使用店铺特定的变量
ETSY_API_KEY_NATURE=nature_shop_api_key
ETSY_API_SECRET_NATURE=nature_shop_api_secret

ETSY_API_KEY_SHOP2=shop2_api_key
ETSY_API_SECRET_SHOP2=shop2_api_secret

# ============================================
# 飞书配置
# ============================================
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 飞书机器人Webhook（可选，用于通知）
FEISHU_BOT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# ============================================
# 邮箱配置
# ============================================
# Yahoo邮箱
EMAIL_ADDRESS_NATURE=nature@yahoo.com
EMAIL_PASSWORD_NATURE=your_yahoo_app_password

EMAIL_ADDRESS_SHOP2=shop2@yahoo.com
EMAIL_PASSWORD_SHOP2=your_yahoo_app_password

# Gmail（如果使用）
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ============================================
# 云途物流配置
# ============================================
YUNEXPRESS_CUSTOMER_ID=your_customer_id
YUNEXPRESS_API_KEY=your_api_key
YUNEXPRESS_API_SECRET=your_api_secret

# ============================================
# 泰嘉物流配置
# ============================================
TAKESEND_CLIENT_ID=your_client_id
TAKESEND_AUTH_TOKEN=your_auth_token

# ============================================
# AI配置（订单解析）
# ============================================
# OpenAI
OPENAI_API_KEY=sk-xxxxx

# Anthropic Claude（如果使用）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================
# Label MVP 服务（可选）
# ============================================
LABEL_MVP_URL=https://your-label-service.railway.app/api/label

# ============================================
# 其他配置
# ============================================
# IOSS代码（欧盟订单）
IOSS_CODE=IM3720000224

# 环境（development, production）
ENVIRONMENT=development

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

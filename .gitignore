# Etsy Multi-Tenant System

# ============================================
# 环境变量文件（包含API密钥、密码等敏感信息）
# ⚠️ 重要：永远不要提交 .env 文件到Git！
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 日志文件
# ============================================
*.log
logs/

# ============================================
# Python
# ============================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
venv/
env/
ENV/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 店铺配置文件（包含商业信息，不应公开）
# ⚠️ 重要：实际店铺配置不要提交到Git！
# ⚠️ 只保留 template.yaml 作为示例模板
# ============================================
configs/shops/*.yaml
!configs/shops/template.yaml

# ============================================
# 产品数据（可能包含商业信息）
# ============================================
data/products_*.json

# ============================================
# 浏览器用户数据（包含登录状态）
# ============================================
.etsy-chrome-profile/
.playwright/

# ============================================
# 临时文件
# ============================================
*.tmp
*.bak
*.swp
.DS_Store
